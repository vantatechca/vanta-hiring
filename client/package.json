    "typescript": "^5.9.3",
    "vite": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^5.2.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.2"
